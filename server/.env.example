# Copy to .env and fill in your own values
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/tatty-travels?retryWrites=true&w=majority
PORT=4000
# Comma-separate multiple origins. On Render, set this to your deployed frontend URL.
CLIENT_ORIGIN=http://localhost:5173
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
JWT_SECRET=replace-with-a-long-random-string
NOMINATIM_EMAIL=you@example.com
