# Copy to .env and fill in your own values
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/tatty-travels?retryWrites=true&w=majority
PORT=4000
# Extra allowed browser origins (comma-separated), added on top of the built-in
# defaults (localhost:5173 + the Netlify frontend). Usually you can leave this unset.
CLIENT_ORIGIN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
JWT_SECRET=replace-with-a-long-random-string
NOMINATIM_EMAIL=you@example.com
